OCIS_BASE_DATA_PATH={{.BaseDir}}
OCIS_CONFIG_DIR={{.ConfigDir}}
OCIS_DEFAULT_LANGUAGE={{.Language}}

OCIS_LOG_LEVEL={{.LogLevel}}
OCIS_LOG_COLOR=false
OCIS_LOG_PRETTY=false

OCIS_ACCESS_TOKEN_LIFETIME=720h
OCIS_ID_TOKEN_LIFETIME=720h

OCIS_ADMIN_USER_ID={{.AdminName}}
OCIS_ADMIN_USER_EMAIL={{.AdminEmail}}
OCIS_ADMIN_PASSWORD={{.Password}}

OCIS_URL=https://{{.FQDN}}
PROXY_HTTP_ADDR=127.0.0.1:9200
OCIS_INSECURE=true
PROXY_TLS=false

STORAGE_USERS_OCIS_DISABLE_VERSIONING=true
UPLOADS_EXPIRE=24h
TRASH_EXPIRE=24h
THUMBNAILS_ENABLED=false

OCIS_DISABLE_SERVICES=search

WEB_UI_CONFIG=/usr/local/share/ocis/web/config.json

